NODE_ENV=development
PORT=5000
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=
DATA_DIR=./backend/data
APP_BASE_URL=http://localhost:5000

# SMTP email (required for password-reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ALABOUD Business Suite <no-reply@example.com>

# Development/testing only. Never enable in production.
RETURN_RESET_TOKEN=false

# Optional integration encryption secret
INTEGRATION_SECRET=
